<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.gui.controller.BidderController">

    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
        <Label text="SỐ DƯ KHẢ DỤNG:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        <Label fx:id="balanceLabel" text="0 ₫" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Nạp tiền" onAction="#handleDeposit" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="Làm mới" onAction="#handleRefresh" style="-fx-base: #bdc3c7; -fx-cursor: hand;"/>
    </HBox>

    <Label text="LỊCH SỬ ĐẶT GIÁ CỦA TÔI" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <TableView fx:id="bidHistoryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colItemName" text="Tên Sản Phẩm" prefWidth="250.0"/>
            <TableColumn fx:id="colBidAmount" text="Mức giá bạn đặt" prefWidth="150.0"/>
            <TableColumn fx:id="colBidTime" text="Thời gian đặt" prefWidth="150.0"/>
            <TableColumn fx:id="colCurrentHighest" text="Giá cao nhất hiện tại" prefWidth="150.0"/>
            <TableColumn fx:id="colAuctionStatus" text="Trạng thái phiên" prefWidth="120.0"/>
            <TableColumn fx:id="colAction" text="Thao tác" prefWidth="100.0"/>
        </columns>
    </TableView>
</VBox>