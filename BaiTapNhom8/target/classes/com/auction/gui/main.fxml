<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.gui.controller.MainController"
            prefWidth="1150.0" prefHeight="720.0">
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 10 20;">
            <Label text="HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="userInfoLabel" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        </HBox>
    </top>
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE"/>
    </center>
</BorderPane>